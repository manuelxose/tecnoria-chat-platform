{
  "name": "tecnoria-chat-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Decoupled enterprise chatbot platform for Tecnoria and future clients.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run -w @tecnoria-chat/chat-api dev",
    "dev:ingest": "npm run -w @tecnoria-chat/ingest-worker dev",
    "dev:widget": "npm run -w @tecnoria-chat/widget serve",
    "cli": "npm run -w @tecnoria-chat/ops-cli cli",
    "test": "npm run test --workspaces --if-present"
  }
}
