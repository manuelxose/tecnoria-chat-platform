{
  "name": "@tecnoria-chat/chat-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json && node ../../scripts/write-entry-shim.mjs dist/main.js ./apps/chat-api/src/main.js",
    "migrate": "tsx src/migrate.ts",
    "seed:portal": "tsx src/seed-portal.ts",
    "seed:talkaris": "tsx src/seed-portal.ts",
    "test": "tsx --test src/**/*.test.ts",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@tecnoria-chat/domain": "0.1.0",
    "@tecnoria-chat/application": "0.1.0",
    "@tecnoria-chat/infrastructure": "0.1.0",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@tecnoria-chat/core": "0.1.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^7.0.3",
    "openai": "^6.27.0",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.13.14",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
